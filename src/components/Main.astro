---
import { getEntry, render } from "astro:content";

const mainEntry = await getEntry("main", "main");
if (!mainEntry) {
  throw new Error("Main content (main/main) not found.");
}
const { Content } = await render(mainEntry);
const {
  title,
  subtitle,
  contact,
  clientsTitle,
  clientNames,
  skillsTitle,
  skills,
} = mainEntry.data;
---

<main id="main" class="main" role="main">
  <div id="information" class="main__grid">
    <section class="main__col main__info">
      <span class="main__caption">Contact</span>
      <h1 class="main__title">{title}</h1>
      <p class="main__subtitle">{subtitle}</p>
      <div class="main__intro">
        <Content />
      </div>
      <p>
        <a href={`mailto:${contact}`} class="main__email">{contact}</a>
      </p>
    </section>
    <section class="main__col main__clients" aria-labelledby="clients-heading">
      <span class="main__caption" id="clients-heading">{clientsTitle}</span>
      <ul class="main__list">
        {clientNames.map((name) => <li>{name}</li>)}
      </ul>
    </section>
    <section class="main__col main__skills" aria-labelledby="skills-heading">
      <span class="main__caption" id="skills-heading">{skillsTitle}</span>
      <ul class="main__list">
        {skills.map((skill) => <li>{skill}</li>)}
      </ul>
    </section>
  </div>
</main>

<style scoped>
  .main {
    padding: var(--space-xl, 3rem) var(--space-l, 2rem);
    flex: 1;
  }
  .main__grid {
    display: grid;
    gap: var(--space-xl, 3rem);
    max-width: 75rem;
  }
  @media (min-width: 45rem) {
    .main__grid {
      grid-template-columns: 3fr 1fr 1fr;
    }
  }
  .main__col {
    min-width: 0;
  }
  .main__title {
    font-size: var(--step-4, 2.5rem);
    font-weight: 400;
    margin: 0;
    letter-spacing: 0.02em;
  }
  .main__subtitle {
    font-size: var(--step-0, 1rem);
    color: var(--color-text-muted);
    margin: var(--space-s, 1rem) 0;
  }
  .main__intro {
    font-size: var(--step-0, 1rem);
    line-height: 1.6;
    max-width: 65ch;
  }
  .main__intro :global(p) {
    margin: 0 0 var(--space-m, 1.5rem);
  }
  .main__email {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .main__email:hover {
    text-decoration: none;
  }
  .main__caption {
    display: block;
    font-family: var(--font-mono, "Geist Mono", ui-monospace, monospace);
    font-size: var(--step--2, 0.75rem);
    font-weight: 475;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-s, 1rem);
    letter-spacing: 0.02em;
  }
  .main__col-title {
    font-size: var(--step--1, 0.875rem);
    font-weight: 500;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-s, 1rem);
    letter-spacing: 0.02em;
  }
  .main__list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--step-0, 1rem);
  }
  .main__list li {
    margin-bottom: 0.25rem;
  }
</style>
