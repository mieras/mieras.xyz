---
import { getCurrentWeather } from "../lib/weather";

let tempDisplay = "--";
try {
  const weather = await getCurrentWeather("Rotterdam");
  if (weather?.current?.temp_c != null) {
    tempDisplay = String(Math.round(weather.current.temp_c));
  }
} catch {
  // keep -- on error
}
const year = new Date().getFullYear();
const today = new Date().toLocaleDateString("en-US", {
  weekday: "long",
  month: "long",
  day: "numeric",
});
---

<footer class="footer" role="contentinfo">
  <div class="footer__col footer__col--1">
    <p class="footer__line">
      © {year} mieras.xyz
    </p>
    <p class="footer__line footer__line--date">
      Today is: {today}
    </p>
  </div>
  <div class="footer__col footer__col--2">
    <p class="footer__line">
      Rotterdam, {tempDisplay}°C
    </p>
    <p class="footer__line">
      <time id="live-time" datetime="">00:00:00:000</time>
    </p>
  </div>
</footer>

<script>
  function pad(n: number, len = 2) {
    return String(n).padStart(len, "0");
  }
  function updateTime() {
    const el = document.getElementById("live-time");
    if (!el) return;
    const d = new Date();
    const h = pad(d.getHours());
    const m = pad(d.getMinutes());
    const s = pad(d.getSeconds());
    const ms = pad(d.getMilliseconds(), 3);
    el.textContent = `${h}:${m}:${s}:${ms}`;
    el.setAttribute("datetime", d.toISOString());
  }
  updateTime();
  setInterval(updateTime, 50);
</script>

<style>
  .footer {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xs, 2rem) var(--space-xs, 3rem);
    align-items: start;
    padding: var(--space-2xs, 3rem) var(--space-xs, 2rem);
    font-size: calc(0.8 * var(--step--3, 0.75rem));
    color: var(--color-color-bg);
    line-height: 133%;
  }
  .footer__col--2 {
  }
  .footer__line {
    margin: 0;
  }
</style>
