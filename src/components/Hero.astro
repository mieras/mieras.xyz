---
// Hero: mega marquee met mieras.xyz (één richting) en coming soon 10× (andere richting), seamless met GSAP
---

<section class="hero" aria-label="Hero">
  <div class="hero__marquee hero__marquee--brand">
    <div class="hero__marquee-inner" data-marquee="brand">
      <span class="hero__marquee-text" aria-hidden="true">mieras.xyz</span>
      <span class="hero__marquee-text" aria-hidden="true">mieras.xyz</span>
    </div>
  </div>
  <div class="hero__marquee hero__marquee--tagline">
    <div class="hero__marquee-inner" data-marquee="tagline">
      <span class="hero__marquee-text hero__marquee-text--tagline" aria-hidden="true">
        coming soon coming soon coming soon coming soon coming soon coming soon coming soon coming soon coming soon coming soon
      </span>
      <span class="hero__marquee-text hero__marquee-text--tagline" aria-hidden="true">
        coming soon coming soon coming soon coming soon coming soon coming soon coming soon coming soon coming soon coming soon
      </span>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  function initMarquees() {
    const brandInner = document.querySelector('[data-marquee="brand"]');
    const taglineInner = document.querySelector('[data-marquee="tagline"]');
    if (!brandInner || !taglineInner) return;

    // mieras.xyz: beweeg naar links (content gaat rechts → links)
    gsap.to(brandInner, {
      xPercent: -50,
      duration: 18,
      repeat: -1,
      ease: 'none',
    });

    // coming soon: start op 50%, animeer naar 0 → content beweegt naar rechts (andere kant op)
    gsap.fromTo(
      taglineInner,
      { xPercent: 50 },
      {
        xPercent: 0,
        duration: 22,
        repeat: -1,
        ease: 'none',
      }
    );
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMarquees);
  } else {
    initMarquees();
  }
</script>

<style scoped>
  .hero {
    width: 100%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .hero__marquee {
    overflow: hidden;
    white-space: nowrap;
    user-select: none;
  }

  .hero__marquee-inner {
    display: inline-flex;
    width: max-content;
    will-change: transform;
  }

  .hero__marquee-text {
    flex-shrink: 0;
    padding-right: 0.4em;
    font-size: clamp(2.5rem, 12vw, 8rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .hero__marquee-text--tagline {
    font-size: clamp(1rem, 4vw, 1.75rem);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    padding-right: 1.5em;
  }
</style>
