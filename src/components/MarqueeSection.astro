---
interface Props {
  text: string;
  href?: string;
  /** CSS value, e.g. #00c600 or var(--marquee-1) */
  backgroundColor: string;
  /** Use light (white) text for dark backgrounds */
  light?: boolean;
  /** Animation duration in seconds (higher = slower) */
  speed?: number;
}

const { text, href, backgroundColor, light = false, speed = 25 } = Astro.props;
---

<section
  class:list={["marquee-section", light && "marquee-section--light"]}
  style={{ backgroundColor, "--marquee-speed": `${speed}s` }}
  aria-label="Marquee"
>
  <div class="marquee-section__track">
    <div class="marquee-section__inner">
      {
        href ? (
          <a href={href} class="marquee-section__link">
            {text}
          </a>
        ) : (
          <span class="marquee-section__text">{text}</span>
        )
      }
      {
        href ? (
          <a href={href} class="marquee-section__link" aria-hidden="true">
            {text}
          </a>
        ) : (
          <span class="marquee-section__text" aria-hidden="true">
            {text}
          </span>
        )
      }
    </div>
  </div>
</section>

<style>
  .marquee-section {
    --marquee-speed: 25s;
    padding: var(--space-s) 0;
    min-height: 20vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    border-radius: var(--space-xs, 0.5rem);
    margin: 0 var(--space-s, 1rem) var(--space-s, 1rem);
  }

  .marquee-section--light .marquee-section__link,
  .marquee-section--light .marquee-section__text {
    color: rgba(255, 255, 255, 0.85);
  }

  .marquee-section__track {
    width: 100%;
    overflow: hidden;
  }

  .marquee-section__inner {
    display: inline-flex;
    width: max-content;
    animation: marquee-scroll var(--marquee-speed) linear infinite;
    will-change: transform;
  }

  .marquee-section__link,
  .marquee-section__text {
    flex-shrink: 0;
    padding-right: 0.5em;
    font-size: var(--step-5, clamp(3rem, 8vw, 9rem));
    font-weight: 700;
    line-height: 100%;
    letter-spacing: -0.03em;
    color: var(--color-text);
    white-space: nowrap;
  }

  .marquee-section__link {
    text-decoration: none;
    color: inherit;
  }

  .marquee-section__link:hover {
    opacity: 0.85;
  }

  .marquee-section__link:active {
    opacity: 0.7;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
