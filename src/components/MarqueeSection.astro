---
interface Props {
    text: string;
    href?: string;
    /** CSS value, e.g. #00c600 or var(--marquee-1) */
    backgroundColor: string;
    /** CSS value for text color, e.g. rgba(255,255,255,0.85) */
    textColor?: string;
    /** Animation speed: higher = slower (maps to CSS duration in seconds) */
    speed?: number;
}

const { text, href, backgroundColor, textColor, speed = 25 } = Astro.props;

// 4 copies — ensures content always fills the viewport even for short texts
const copies = Array(4).fill(null);
---

<section
    class="marquee-section"
    style={{
        backgroundColor,
        "--marquee-text-color": textColor ?? "var(--color-text)",
    }}
    data-speed={speed}
    aria-label="Marquee"
>
    <div class="marquee-section__track">
        <div class="marquee-section__inner">
            {
                copies.map((_, i) =>
                    href ? (
                        <a
                            href={href}
                            class="marquee-section__item"
                            aria-hidden={i > 0 ? "true" : undefined}
                        >
                            {text}
                        </a>
                    ) : (
                        <span
                            class="marquee-section__item"
                            aria-hidden={i > 0 ? "true" : undefined}
                        >
                            {text}
                        </span>
                    )
                )
            }
        </div>
    </div>
</section>

<script>
    import gsap from "gsap";

    document
        .querySelectorAll<HTMLElement>(".marquee-section")
        .forEach((section) => {
            const inner = section.querySelector<HTMLElement>(
                ".marquee-section__inner"
            );
            if (!inner) return;

            const speed = parseFloat(section.dataset.speed ?? "25");
            const singleWidth = inner.scrollWidth / 4;
            if (singleWidth <= 0) return;

            const pps = (30 / speed) * 200; // pixels per second
            let pos = 0;
            let dirTarget = 1; // +1 = default (left), -1 = reversed
            let dir = 1;       // lerps towards dirTarget

            gsap.ticker.add((_time, deltaTime) => {
                const lenis = (
                    window as unknown as { lenis?: { velocity: number } }
                ).lenis;
                const vel = lenis?.velocity ?? 0;

                // Only update direction when actually scrolling; hold last dir when idle
                if (vel > 0.5) dirTarget = 1;
                else if (vel < -0.5) dirTarget = -1;

                dir += (dirTarget - dir) * 0.08;

                pos -= pps * (deltaTime / 1000) * dir;
                if (pos < -singleWidth) pos += singleWidth;
                if (pos > 0) pos -= singleWidth;

                inner.style.transform = `translateX(${pos}px)`;
            });
        });
</script>

<style>
    .marquee-section {
        --marquee-rotate: 0deg;
        --marquee-x: 0px;
        --marquee-y: 0px;
        padding: var(--space-2xs) 0;
        display: flex;
        align-items: center;
        overflow: hidden;
        border-radius: var(--space-2xs, 0.5rem);
        margin: 0 var(--space-2xs, 1rem) var(--space-2xs, 1rem);
        transform: translate3d(var(--marquee-x), var(--marquee-y), 0)
            rotate(var(--marquee-rotate));
        transform-origin: center;
        transition: transform 320ms ease;
    }
    @media (min-width: 1280px) {
        .marquee-section {
            min-height: 10vh;
        }
    }

    .marquee-section__track {
        width: 100%;
        overflow: hidden;
    }

    .marquee-section__inner {
        display: flex;
        width: max-content;
        will-change: transform;
    }

    .marquee-section__item {
        flex-shrink: 0;
        padding-right: 0.5ch;
        font-size: var(--step-5, clamp(3rem, 8vw, 9rem));
        font-weight: 700;
        line-height: 100%;
        letter-spacing: -0.01em;
        color: var(--marquee-text-color);
        white-space: nowrap;
        text-decoration: none;
        display: block;
    }

    a.marquee-section__item:hover {
        opacity: 0.85;
    }

    a.marquee-section__item:active {
        opacity: 0.7;
    }
</style>
