---
interface Props {
    text: string;
    href?: string;
    /** CSS value, e.g. #00c600 or var(--marquee-1) */
    backgroundColor: string;
    /** CSS value for text color, e.g. rgba(255,255,255,0.85) */
    textColor?: string;
    /** Animation speed: higher = slower (maps to CSS duration in seconds) */
    speed?: number;
}

const { text, href, backgroundColor, textColor, speed = 25 } = Astro.props;

// 4 copies — ensures content always fills the viewport even for short texts
const copies = Array(4).fill(null);
---

<section
    class="marquee-section"
    style={{
        backgroundColor,
        "--marquee-text-color": textColor ?? "var(--color-text)",
    }}
    data-speed={speed}
    aria-label="Marquee"
>
    <div class="marquee-section__track">
        <div class="marquee-section__inner">
            {
                copies.map((_, i) =>
                    href ? (
                        <a
                            href={href}
                            class="marquee-section__item"
                            aria-hidden={i > 0 ? "true" : undefined}
                        >
                            {text}
                        </a>
                    ) : (
                        <span
                            class="marquee-section__item"
                            aria-hidden={i > 0 ? "true" : undefined}
                        >
                            {text}
                        </span>
                    )
                )
            }
        </div>
    </div>
</section>

<script>
    // Measure each marquee's width once at startup, then CSS handles the loop.
    document
        .querySelectorAll<HTMLElement>(".marquee-section")
        .forEach((section) => {
            const inner = section.querySelector<HTMLElement>(
                ".marquee-section__inner"
            );
            if (!inner) return;

            const speed = parseFloat(section.dataset.speed ?? "25");
            const singleWidth = inner.scrollWidth / 4;
            const pps = (30 / speed) * 200;
            section.style.setProperty("--marquee-duration", `${singleWidth / pps}s`);
            section.style.setProperty("--marquee-translate", `-${singleWidth}px`);
            inner.style.animationPlayState = "running";
        });
</script>

<style>
    .marquee-section {
        --marquee-rotate: 0deg;
        --marquee-x: 0px;
        --marquee-y: 0px;
        --marquee-duration: 20s;
        padding: var(--space-2xs) 0;
        display: flex;
        align-items: center;
        overflow: hidden;
        border-radius: var(--space-2xs, 0.5rem);
        margin: 0 var(--space-2xs, 1rem) var(--space-2xs, 1rem);
        transform: translate3d(var(--marquee-x), var(--marquee-y), 0)
            rotate(var(--marquee-rotate));
        transform-origin: center;
        transition: transform 320ms ease;
    }
    @media (min-width: 1280px) {
        .marquee-section {
            min-height: 10vh;
        }
    }

    .marquee-section__track {
        width: 100%;
        overflow: hidden;
    }

    .marquee-section__inner {
        display: flex;
        width: max-content;
        will-change: transform;
        animation: marquee-scroll var(--marquee-duration) linear infinite;
        animation-play-state: paused; /* JS sets to running once duration is ready */
    }

    @keyframes marquee-scroll {
        to {
            transform: translateX(var(--marquee-translate, -25%));
        }
    }

    .marquee-section__item {
        flex-shrink: 0;
        padding-right: 0.5ch;
        font-size: var(--step-5, clamp(3rem, 8vw, 9rem));
        font-weight: 700;
        line-height: 100%;
        letter-spacing: -0.01em;
        color: var(--marquee-text-color);
        white-space: nowrap;
        text-decoration: none;
        display: block;
    }

    a.marquee-section__item:hover {
        opacity: 0.85;
    }

    a.marquee-section__item:active {
        opacity: 0.7;
    }
</style>
