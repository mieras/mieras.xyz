---
interface Props {
    contact?: string;
}

const { contact = "studio@mieras.xyz" } = Astro.props;
---

<header class="header" role="banner">
    <a href="/" class="header__name" rel="home">mieras.xyz</a>
    <nav class="header__nav" aria-label="Navigation">
        <a href="#information" class="header__link">info</a>
        <a href={`mailto:${contact}`} class="header__link">mail</a>
    </nav>
</header>

<style scoped>
    .header {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-2xs, 2rem);
        align-items: center;
        position: relative;
        z-index: 1000;
        padding: 9px 14px;
    }
    .header__name {
        grid-column: 1 / 3;
        font-size: var(--step--1);
        font-weight: 450;
        color: var(--color-text);
        text-decoration: none;
        line-height: 1;
    }
    .header__name:hover {
        text-decoration: underline;
    }
    .header__nav {
        grid-column: 3 / 5;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-2xs, 2rem);
        font-size: var(--step--1);
        font-weight: 500;
        color: var(--color-text);
    }
    .header__link {
        color: inherit;
        text-decoration: none;
    }
    .header__link:hover {
        text-decoration: underline;
    }
</style>
