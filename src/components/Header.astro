---
import ThemeToggle from './ThemeToggle.astro';
import { getCurrentWeather } from '../lib/weather';

let tempDisplay = '--';
try {
  const weather = await getCurrentWeather('Rotterdam');
  if (weather?.current?.temp_c != null) {
    tempDisplay = String(Math.round(weather.current.temp_c));
  }
} catch {
  // keep -- on error
}
---

<header class="header" role="banner">
  <div class="header__identity">
    <p class="header__name">Maarten Mieras</p>
    <p class="header__title mono">DIGITAL DESIGNER</p>
  </div>
  <div class="header__meta">
    <time id="live-time" class="mono" datetime="">00:00:00:000</time>
    <span class="mono" aria-label="Temperatuur in Rotterdam">{tempDisplay}°C</span>
    <span class="mono header__location">ROTTERDAM</span>
    <ThemeToggle />
  </div>
</header>

<script>
  function pad(n: number, len = 2) {
    return String(n).padStart(len, '0');
  }
  function updateTime() {
    const el = document.getElementById('live-time');
    if (!el) return;
    const d = new Date();
    const h = pad(d.getHours());
    const m = pad(d.getMinutes());
    const s = pad(d.getSeconds());
    const ms = pad(d.getMilliseconds(), 3);
    el.textContent = `${h}:${m}:${s}:${ms}`;
    el.setAttribute('datetime', d.toISOString());
  }
  updateTime();
  setInterval(updateTime, 50);
</script>

<style scoped>
  .header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-s, 1rem);
    padding: var(--space-m, 1.5rem) var(--space-l, 2rem);
    border-bottom: 1px solid var(--color-border);
  }
  .header__name {
    font-size: var(--step-1, 1.25rem);
    font-weight: 500;
    margin: 0;
  }
  .header__title {
    font-size: var(--step--1, 0.875rem);
    margin: 0.25rem 0 0;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }
  .header__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-m, 1.5rem);
    font-size: var(--step--1, 0.875rem);
    color: var(--color-text-muted);
  }
  .header__location {
    letter-spacing: 0.05em;
  }
</style>
