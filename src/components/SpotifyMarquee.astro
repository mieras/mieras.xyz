---
import type { SpotifyTrack } from "../lib/spotify";

interface Props {
    tracks: SpotifyTrack[];
    backgroundColor?: string;
    textColor?: string;
    speed?: number;
}

const {
    tracks,
    backgroundColor = "#1DB954",
    textColor = "var(--color-bg)",
    speed = 35,
} = Astro.props;
---

{
    tracks.length > 0 && (
        <section
            class="spotify-marquee"
            style={{
                backgroundColor,
                "--spotify-text-color": textColor,
            }}
            data-speed={speed}
            aria-label="Recently played on Spotify"
        >
            <div class="spotify-marquee__label" aria-hidden="true">
                now playing
            </div>
            <div class="spotify-marquee__track">
                <div class="spotify-marquee__inner">
                    {tracks.map((track) => (
                        <a
                            class="spotify-marquee__item"
                            href={track.trackUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={`${track.artist} — ${track.title}`}
                        >
                            {track.albumArt && (
                                <img
                                    class="spotify-marquee__thumb"
                                    src={track.albumArt}
                                    alt=""
                                    aria-hidden="true"
                                    width="48"
                                    height="48"
                                    loading="lazy"
                                />
                            )}
                            <span class="spotify-marquee__text">
                                {track.artist} • {track.title}
                            </span>
                            <span
                                class="spotify-marquee__sep"
                                aria-hidden="true"
                            >
                                {""}
                            </span>
                        </a>
                    ))}
                </div>
            </div>
        </section>
    )
}

<script>
    import gsap from "gsap";
    import { Draggable } from "gsap/Draggable";
    import { InertiaPlugin } from "gsap/InertiaPlugin";
    import { horizontalLoop } from "../lib/horizontalLoop";

    gsap.registerPlugin(Draggable, InertiaPlugin);

    const section = document.querySelector<HTMLElement>(".spotify-marquee");
    if (section) {
        const items = Array.from(
            section.querySelectorAll<HTMLElement>(".spotify-marquee__item")
        );
        if (items.length > 0) {
            const speed = parseFloat(section.dataset.speed ?? "35");
            // Map to horizontalLoop speed unit: pixelsPerSecond / 100
            const hlSpeed = (30 / speed) * 2;

            const tl = horizontalLoop(items, {
                repeat: -1,
                speed: hlSpeed,
                paused: false,
            });

            // Draggable proxy: maps horizontal drag to timeline progress
            const proxy = document.createElement("div");
            const wrapProgress = gsap.utils.wrap(0, 1);
            const ratio = 1 / tl.totalWidth;
            let startProgress = 0;
            let wasPlaying = false;
            let d: Draggable | null = null;

            const align = () => {
                if (!d) return;
                tl.progress(
                    wrapProgress(startProgress + (d.startX - d.x) * ratio)
                );
            };

            d = Draggable.create(proxy, {
                trigger: section.querySelector(".spotify-marquee__inner"),
                type: "x",
                cursor: "none",
                activeCursor: "none",
                onPressInit() {
                    wasPlaying = !tl.paused();
                    gsap.killTweensOf(tl);
                    tl.pause();
                    startProgress = tl.progress();
                    gsap.set(proxy, { x: startProgress / -ratio });
                },
                onDrag: align,
                onThrowUpdate: align,
                inertia: true,
                overshootTolerance: 0,
                onRelease() {
                    // No throw (e.g. simple click): resume after one tick
                    // so isThrowing has time to be set if a throw did start
                    requestAnimationFrame(() => {
                        if (!d?.isThrowing && wasPlaying) tl.play();
                    });
                },
                onThrowComplete() {
                    if (wasPlaying) tl.play();
                },
            })[0];

            // Mirror the original ticker logic: lerp direction + hover multiplier,
            // applied as timeScale so Draggable can take over progress when needed.
            let dirTarget = 1;
            let dir = 1;
            let isHovering = false;

            gsap.ticker.add(() => {
                if (d?.isDragging || d?.isThrowing) return;

                const vel = (
                    window as unknown as { lenis?: { velocity: number } }
                ).lenis?.velocity ?? 0;

                // Only update direction when actively scrolling; hold last when idle
                if (vel > 0.5) dirTarget = 1;
                else if (vel < -0.5) dirTarget = -1;

                dir += ((isHovering ? 0 : dirTarget) - dir) * 0.08;
                tl.timeScale(dir);
            });

            section.addEventListener("mouseenter", () => { isHovering = true; });
            section.addEventListener("mouseleave", () => { isHovering = false; });
        }
    }
</script>

<style>
    .spotify-marquee {
        --marquee-rotate: 0deg;
        --marquee-x: 0px;
        --marquee-y: 0px;
        padding: var(--space-2xs) 0;
        display: flex;
        align-items: center;
        overflow: hidden;
        border-radius: var(--space-2xs, 0.5rem);
        margin: 0 var(--space-2xs, 1rem) var(--space-2xs, 1rem);
        transform: translate3d(var(--marquee-x), var(--marquee-y), 0)
            rotate(var(--marquee-rotate));
        transform-origin: center;
        transition: transform 320ms ease;
    }

    @media (min-width: 1280px) {
        .spotify-marquee {
            min-height: 10vh;
        }
    }

    .spotify-marquee__label {
        position: absolute;
        left: var(--space-xs);
        top: 50%;
        transform: translateY(-50%);
        flex-shrink: 0;
        align-self: stretch;
        display: flex;
        align-items: center;
        padding: var(--space-xs) var(--space-s);
        background-color: rgb(from var(--color-bg) r g b / 0.4);
        backdrop-filter: blur(var(--cursor-blur));
        color: var(--color-text);
        font-size: var(--step--1);
        font-weight: 500;
        white-space: nowrap;
        border-radius: 9999px;
        z-index: 1;
        pointer-events: none;
    }

    .spotify-marquee__track {
        width: 100%;
        overflow: hidden;
        cursor: grab;
        user-select: none;
    }

    .spotify-marquee__track:active {
        cursor: grabbing;
    }

    .spotify-marquee__inner {
        display: flex;
        width: max-content;
        align-items: center;
    }

    .spotify-marquee__item {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: var(--space-xs, 0.75rem);
        padding-right: var(--space-xs, 0.75rem);
        color: var(--spotify-text-color);
        text-decoration: none;
        will-change: transform;
    }

    .spotify-marquee__item:hover {
        opacity: 0.85;
    }

    .spotify-marquee__item:active {
        opacity: 0.7;
    }

    .spotify-marquee__thumb {
        display: block;
        flex-shrink: 0;
        width: 3em;
        height: 3em;
        border-radius: var(--space-3xs, 0.25rem);
        object-fit: cover;
    }

    .spotify-marquee__text {
        font-size: var(--step-5, clamp(3rem, 8vw, 9rem));
        font-weight: 700;
        line-height: 100%;
        letter-spacing: -0.01em;
        white-space: nowrap;
    }

    .spotify-marquee__sep {
        font-size: var(--step-5);
        opacity: 0.4;
    }
</style>
