---
import type { SpotifyTrack } from "../lib/spotify";

interface Props {
    tracks: SpotifyTrack[];
    backgroundColor?: string;
    textColor?: string;
    speed?: number;
}

const {
    tracks,
    backgroundColor = "#1DB954",
    textColor = "var(--color-bg)",
    speed = 35,
} = Astro.props;

// 2 groups — CSS translateX(-50%) loop needs exactly two identical copies
const groupCount = 2;
---

{
    tracks.length > 0 && (
        <section
            class="spotify-marquee"
            style={{
                backgroundColor,
                "--spotify-text-color": textColor,
            }}
            data-speed={speed}
            aria-label="Recently played on Spotify"
        >
            <div class="spotify-marquee__label" aria-hidden="true">
                now playing
            </div>
            <div class="spotify-marquee__track">
                <div class="spotify-marquee__inner">
                    {Array.from({ length: groupCount }, (_, groupIndex) => (
                        <div
                            class="spotify-marquee__group"
                            aria-hidden={groupIndex > 0 ? "true" : undefined}
                        >
                            {tracks.map((track) => (
                                <a
                                    class="spotify-marquee__item"
                                    href={track.trackUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    aria-label={
                                        groupIndex === 0
                                            ? `${track.artist} — ${track.title}`
                                            : undefined
                                    }
                                    tabindex={groupIndex > 0 ? -1 : undefined}
                                >
                                    {track.albumArt && (
                                        <img
                                            class="spotify-marquee__thumb"
                                            src={track.albumArt}
                                            alt=""
                                            aria-hidden="true"
                                            width="48"
                                            height="48"
                                            loading="lazy"
                                        />
                                    )}
                                    <span class="spotify-marquee__text">
                                        {track.artist} • {track.title}
                                    </span>
                                    <span
                                        class="spotify-marquee__sep"
                                        aria-hidden="true"
                                    >
                                        {""}
                                    </span>
                                </a>
                            ))}
                        </div>
                    ))}
                </div>
            </div>
        </section>
    )
}

<script>
    const section = document.querySelector<HTMLElement>(".spotify-marquee");
    if (section) {
        const inner = section.querySelector<HTMLElement>(
            ".spotify-marquee__inner"
        );
        if (inner) {
            // Measure one group's width once, then CSS handles the loop.
            const speed = parseFloat(section.dataset.speed ?? "35");
            const singleWidth = inner.scrollWidth / 2;
            const pps = (30 / speed) * 200;
            section.style.setProperty("--marquee-duration", `${singleWidth / pps}s`);
            section.style.setProperty("--marquee-translate", `-${singleWidth}px`);
            inner.style.animationPlayState = "running";

            // Pause on hover so links are easy to click
            section.addEventListener("mouseenter", () => {
                inner.classList.add("is-paused");
            });
            section.addEventListener("mouseleave", () => {
                inner.classList.remove("is-paused");
            });
        }
    }
</script>

<style>
    .spotify-marquee {
        --marquee-rotate: 0deg;
        --marquee-x: 0px;
        --marquee-y: 0px;
        --marquee-duration: 20s;
        padding: var(--space-2xs) 0;
        display: flex;
        align-items: center;
        overflow: hidden;
        border-radius: var(--space-2xs, 0.5rem);
        margin: 0 var(--space-2xs, 1rem) var(--space-2xs, 1rem);
        transform: translate3d(var(--marquee-x), var(--marquee-y), 0)
            rotate(var(--marquee-rotate));
        transform-origin: center;
        transition: transform 320ms ease;
    }

    @media (min-width: 1280px) {
        .spotify-marquee {
            min-height: 10vh;
        }
    }

    .spotify-marquee__label {
        position: absolute;
        left: var(--space-s);
        top: 50%;
        transform: translateY(-50%);
        flex-shrink: 0;
        align-self: stretch;
        display: flex;
        align-items: center;
        padding: var(--space-xs) var(--space-s);
        background-color: rgb(from var(--color-bg) r g b / 0.4);
        backdrop-filter: blur(var(--cursor-blur));
        color: var(--color-text);
        font-size: var(--step--1);
        font-weight: 500;
        white-space: nowrap;
        border-radius: 9999px;
        z-index: 1;
    }

    .spotify-marquee__track {
        width: 100%;
        overflow: hidden;
    }

    .spotify-marquee__inner {
        display: flex;
        width: max-content;
        align-items: center;
        will-change: transform;
        animation: spotify-scroll var(--marquee-duration) linear infinite;
        animation-play-state: paused; /* JS sets to running once duration is ready */
    }

    .spotify-marquee__inner.is-paused {
        animation-play-state: paused;
    }

    @keyframes spotify-scroll {
        to {
            transform: translateX(var(--marquee-translate, -50%));
        }
    }

    .spotify-marquee__group {
        display: flex;
        flex-shrink: 0;
        align-items: center;
    }

    .spotify-marquee__item {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: var(--space-xs, 0.75rem);
        padding-right: var(--space-xs, 0.75rem);
        color: var(--spotify-text-color);
        text-decoration: none;
    }

    .spotify-marquee__item:hover {
        opacity: 0.85;
    }

    .spotify-marquee__item:active {
        opacity: 0.7;
    }

    .spotify-marquee__thumb {
        display: block;
        flex-shrink: 0;
        width: 3em;
        height: 3em;
        border-radius: var(--space-3xs, 0.25rem);
        object-fit: cover;
    }

    .spotify-marquee__text {
        font-size: var(--step-5, clamp(3rem, 8vw, 9rem));
        font-weight: 700;
        line-height: 100%;
        letter-spacing: -0.01em;
        white-space: nowrap;
    }

    .spotify-marquee__sep {
        font-size: var(--step-5);
        opacity: 0.4;
    }
</style>
