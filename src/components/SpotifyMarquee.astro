---
import type { SpotifyTrack } from "../lib/spotify";

interface Props {
    tracks: SpotifyTrack[];
    backgroundColor?: string;
    textColor?: string;
    speed?: number;
}

const {
    tracks,
    backgroundColor = "#1DB954",
    textColor = "var(--color-bg)",
    speed = 35,
} = Astro.props;

// 2 groups — CSS translateX(-50%) loop needs exactly two identical copies
const groupCount = 2;
---

{
    tracks.length > 0 && (
        <section
            class="spotify-marquee"
            style={{
                backgroundColor,
                "--spotify-text-color": textColor,
            }}
            data-speed={speed}
            aria-label="Recently played on Spotify"
        >
            <div class="spotify-marquee__label" aria-hidden="true">
                now playing
            </div>
            <div class="spotify-marquee__track">
                <div class="spotify-marquee__inner">
                    {Array.from({ length: groupCount }, (_, groupIndex) => (
                        <div
                            class="spotify-marquee__group"
                            aria-hidden={groupIndex > 0 ? "true" : undefined}
                        >
                            {tracks.map((track) => (
                                <a
                                    class="spotify-marquee__item"
                                    href={track.trackUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    aria-label={
                                        groupIndex === 0
                                            ? `${track.artist} — ${track.title}`
                                            : undefined
                                    }
                                    tabindex={groupIndex > 0 ? -1 : undefined}
                                >
                                    {track.albumArt && (
                                        <img
                                            class="spotify-marquee__thumb"
                                            src={track.albumArt}
                                            alt=""
                                            aria-hidden="true"
                                            width="48"
                                            height="48"
                                            loading="lazy"
                                        />
                                    )}
                                    <span class="spotify-marquee__text">
                                        {track.artist} • {track.title}
                                    </span>
                                    <span
                                        class="spotify-marquee__sep"
                                        aria-hidden="true"
                                    >
                                        {""}
                                    </span>
                                </a>
                            ))}
                        </div>
                    ))}
                </div>
            </div>
        </section>
    )
}

<script>
    import gsap from "gsap";

    const section = document.querySelector<HTMLElement>(".spotify-marquee");
    if (section) {
        const inner = section.querySelector<HTMLElement>(
            ".spotify-marquee__inner"
        );
        if (inner) {
            const speed = parseFloat(section.dataset.speed ?? "35");
            const singleWidth = inner.scrollWidth / 2;
            if (singleWidth > 0) {
                const pps = (30 / speed) * 200; // pixels per second
                let pos = 0;
                let dirTarget = 1; // +1 = default (left), -1 = reversed
                let dir = 1; // lerps towards dirTarget
                let hoverTarget = 1; // 1 = full speed, 0 = stopped
                let hoverMult = 1;

                gsap.ticker.add((_time, deltaTime) => {
                    const lenis = (
                        window as unknown as { lenis?: { velocity: number } }
                    ).lenis;
                    const vel = lenis?.velocity ?? 0;

                    // Only update direction when actually scrolling; hold last dir when idle
                    if (vel > 0.5) dirTarget = 1;
                    else if (vel < -0.5) dirTarget = -1;

                    dir += (dirTarget - dir) * 0.08;
                    hoverMult += (hoverTarget - hoverMult) * 0.08;

                    // Cap deltaTime to prevent large jumps after tab backgrounding / JS throttling
                    const dt = Math.min(deltaTime, 50);
                    pos -= pps * (dt / 1000) * dir * hoverMult;
                    // Modulo wrap — handles any size of jump correctly
                    pos = ((pos % singleWidth) + singleWidth) % singleWidth - singleWidth;

                    inner.style.transform = `translateX(${pos}px)`;
                });

                // Smooth decelerate to stop on hover so links are easy to click.
                section.addEventListener("mouseenter", () => {
                    hoverTarget = 0;
                });
                section.addEventListener("mouseleave", () => {
                    hoverTarget = 1;
                });
            }
        }
    }
</script>

<style>
    .spotify-marquee {
        --marquee-rotate: 0deg;
        --marquee-x: 0px;
        --marquee-y: 0px;
        padding: var(--space-2xs) 0;
        display: flex;
        align-items: center;
        overflow: hidden;
        border-radius: var(--space-2xs, 0.5rem);
        margin: 0 var(--space-2xs, 1rem) var(--space-2xs, 1rem);
        transform: translate3d(var(--marquee-x), var(--marquee-y), 0)
            rotate(var(--marquee-rotate));
        transform-origin: center;
        transition: transform 320ms ease;
    }

    @media (min-width: 1280px) {
        .spotify-marquee {
            min-height: 10vh;
        }
    }

    .spotify-marquee__label {
        position: absolute;
        left: var(--space-xs);
        top: 50%;
        transform: translateY(-50%);
        flex-shrink: 0;
        align-self: stretch;
        display: flex;
        align-items: center;
        padding: var(--space-xs) var(--space-s);
        background-color: rgb(from var(--color-bg) r g b / 0.4);
        backdrop-filter: blur(var(--cursor-blur));
        color: var(--color-text);
        font-size: var(--step--1);
        font-weight: 500;
        white-space: nowrap;
        border-radius: 9999px;
        z-index: 1;
    }

    .spotify-marquee__track {
        width: 100%;
        overflow: hidden;
    }

    .spotify-marquee__inner {
        display: flex;
        width: max-content;
        align-items: center;
        will-change: transform;
    }

    .spotify-marquee__group {
        display: flex;
        flex-shrink: 0;
        align-items: center;
    }

    .spotify-marquee__item {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        gap: var(--space-xs, 0.75rem);
        padding-right: var(--space-xs, 0.75rem);
        color: var(--spotify-text-color);
        text-decoration: none;
    }

    .spotify-marquee__item:hover {
        opacity: 0.85;
    }

    .spotify-marquee__item:active {
        opacity: 0.7;
    }

    .spotify-marquee__thumb {
        display: block;
        flex-shrink: 0;
        width: 3em;
        height: 3em;
        border-radius: var(--space-3xs, 0.25rem);
        object-fit: cover;
    }

    .spotify-marquee__text {
        font-size: var(--step-5, clamp(3rem, 8vw, 9rem));
        font-weight: 700;
        line-height: 100%;
        letter-spacing: -0.01em;
        white-space: nowrap;
    }

    .spotify-marquee__sep {
        font-size: var(--step-5);
        opacity: 0.4;
    }
</style>
