---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Main from "../components/Main.astro";
import Footer from "../components/Footer.astro";
import MarqueeSection from "../components/MarqueeSection.astro";
import { getEntry, getCollection } from "astro:content";

const mainEntry = await getEntry("main", "main");
const contact = mainEntry?.data?.contact ?? "studio@mieras.xyz";

const marqueeEntries = await getCollection("marquee");
const marquees = (marqueeEntries[0]?.data ?? []).sort(
  (a: { order: number }, b: { order: number }) => a.order - b.order
);
---

<BaseLayout
  title="MIERAS.XYZ — Maarten Mieras, Digital Designer"
  description="Maarten Mieras is a Digital Designer with 15+ years of experience, based in Rotterdam. Clear and intuitive digital products, agile methods."
>
  <Header contact={contact} />
  <section class="marquee-wrapper">
    {
      marquees.map((m) => (
        <MarqueeSection
          text={m.text}
          href={m.href}
          backgroundColor={m.backgroundColor}
          textColor={m.textColor}
          speed={m.speed}
        />
      ))
    }
  </section>

  <Main />
  <Footer />
</BaseLayout>

<style>
  .marquee-wrapper {
    margin-bottom: var(--space-2xl, 1rem);
  }
  @media (min-width: 1280px) {
    .marquee-wrapper {
      display: flex;
      flex-direction: column;
      min-height: 100svh;
    }
    :global(.marquee-wrapper > section) {
      flex: 1;
    }
  }
</style>
