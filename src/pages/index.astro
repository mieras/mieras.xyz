---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Main from "../components/Main.astro";
import Footer from "../components/Footer.astro";
import MarqueeSection from "../components/MarqueeSection.astro";
import SpotifyMarquee from "../components/SpotifyMarquee.astro";
import JsonLd from "../components/JsonLd.astro";
import { getEntry, getCollection } from "astro:content";
import { getRecentlyPlayed } from "../lib/spotify";

const mainEntry = await getEntry("main", "main");
const contact = mainEntry?.data?.contact ?? "studio@mieras.xyz";

const marqueeEntries = await getCollection("marquee");
const marquees = (marqueeEntries[0]?.data ?? []).sort(
    (a: { order: number }, b: { order: number }) => a.order - b.order
);

const spotifyTracks = await getRecentlyPlayed(10);

const seoEntry = await getEntry("seo", "seo");
const { person: p, organization: o } = seoEntry!.data;

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: p.name,
    jobTitle: p.jobTitle,
    gender: p.gender,
    email: p.email,
    birthDate: p.birthDate,
    birthPlace: p.birthPlace,
    url: p.url,
    address: {
        "@type": "PostalAddress",
        ...p.address,
    },
};

const organizationSchema = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: o.name,
    url: o.url,
    sameAs: o.sameAs,
    logo: o.logo,
    description: o.description,
    email: o.email,
    hasMap: o.hasMap,
    openingHours: o.openingHours,
    geo: {
        "@type": "GeoCoordinates",
        latitude: o.latitude,
        longitude: o.longitude,
    },
    address: {
        "@type": "PostalAddress",
        ...o.address,
    },
};
---

<BaseLayout
    title={o.metaTitle ?? `${o.name} • ${p.name} • ${p.jobTitle}`}
    description={o.metaDescription ?? o.description}
>
    <Fragment slot="head">
        <JsonLd data={personSchema} />
        <JsonLd data={organizationSchema} />
    </Fragment>
    <Header contact={contact} />
    <section class="marquee-wrapper">
        {
            marquees.map((m) => (
                <MarqueeSection
                    text={m.text}
                    href={m.href}
                    backgroundColor={m.backgroundColor}
                    textColor={m.textColor}
                    speed={m.speed}
                />
            ))
        }
        <SpotifyMarquee tracks={spotifyTracks} />
    </section>

    <Main />
    <Footer />

    <div id="shuffle-cursor" class="shuffle-cursor" aria-hidden="true">
        <svg
            class="cursor-icon cursor-icon--shuffle"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
        >
            <path
                d="M23 14V15H22V17H21V19H20V20H19V21H17V22H15V23H9V22H7V21H5V20H3V21H2V22H1V15H8V16H7V17H6V19H7V20H9V21H15V20H17V19H19V17H20V14H23ZM23 2V9H16V8H17V7H18V5H17V4H15V3H9V4H7V5H5V7H4V10H1V9H2V7H3V5H4V4H5V3H7V2H9V1H15V2H17V3H19V4H21V3H22V2H23Z"
                fill="currentColor"></path>
        </svg>
        <svg
            class="cursor-icon cursor-icon--play"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
        >
            <path d="M8 5.14v14l11-7-11-7z"></path>
        </svg>
    </div>
</BaseLayout>

<script>
    import gsap from "gsap";

    const cursor = document.getElementById("shuffle-cursor");
    const heroWrapper = document.querySelector<HTMLElement>(".marquee-wrapper");
    const isTouch = window.matchMedia("(pointer: coarse)").matches;

    if (cursor && heroWrapper) {
        if (!isTouch) {
            // Desktop: follow mouse with GSAP delay
            const xTo = gsap.quickTo(cursor, "x", {
                duration: 0.5,
                ease: "power3.out",
            });
            const yTo = gsap.quickTo(cursor, "y", {
                duration: 0.5,
                ease: "power3.out",
            });

            window.addEventListener("mousemove", (e) => {
                xTo(e.clientX);
                yTo(e.clientY);
            });

            heroWrapper.addEventListener("mouseenter", () => {
                cursor.classList.add("is-visible");
                heroWrapper.classList.add("cursor-active");
            });

            heroWrapper.addEventListener("mouseleave", () => {
                cursor.classList.remove("is-visible");
                heroWrapper.classList.remove("cursor-active");
            });

            // Hide cursor on regular marquee links; keep visible on Spotify links
            heroWrapper.querySelectorAll<HTMLElement>("a:not(.spotify-marquee__item)").forEach((link) => {
                link.addEventListener("mouseenter", () =>
                    cursor.classList.remove("is-visible")
                );
                link.addEventListener("mouseleave", () =>
                    cursor.classList.add("is-visible")
                );
            });

            // Switch to play icon when hovering Spotify marquee
            const spotifySection = heroWrapper.querySelector<HTMLElement>(".spotify-marquee");
            if (spotifySection) {
                spotifySection.addEventListener("mouseenter", () => {
                    cursor.classList.add("is-play-mode");
                });
                spotifySection.addEventListener("mouseleave", () => {
                    cursor.classList.remove("is-play-mode");
                });
            }
        } else {
            // Mobile: fixed center, hide when bottom of marquee-wrapper scrolls past viewport center
            function checkMobileCursor() {
                const rect = heroWrapper!.getBoundingClientRect();
                const centerY = window.innerHeight / 2;
                if (rect.top < centerY && rect.bottom > centerY) {
                    cursor!.classList.add("is-visible");
                } else {
                    cursor!.classList.remove("is-visible");
                }
            }

            checkMobileCursor();
            window.addEventListener("scroll", checkMobileCursor, {
                passive: true,
            });
        }
    }
</script>

<script>
    const desktopMedia = window.matchMedia("(min-width: 1280px)");
    const wrapper = document.querySelector<HTMLElement>(".marquee-wrapper");
    const toggle = document.getElementById(
        "marquee-refresh-toggle"
    ) as HTMLButtonElement | null;

    if (wrapper) {
        const sections = Array.from(
            wrapper.querySelectorAll<HTMLElement>(".marquee-section, .spotify-marquee")
        );

        const chaosRangeDesktop = { rotate: 8, x: 18, y: 28 };
        const chaosRangeMobile = { rotate: 4, x: 10, y: 24 };

        const randomBetween = (maxAbs: number) =>
            (Math.random() * 2 - 1) * maxAbs;

        const getChaosRange = () =>
            desktopMedia.matches ? chaosRangeDesktop : chaosRangeMobile;

        function setSectionTransform(
            section: HTMLElement,
            range: typeof chaosRangeDesktop
        ) {
            section.style.setProperty(
                "--marquee-rotate",
                `${randomBetween(range.rotate).toFixed(2)}deg`
            );
            section.style.setProperty(
                "--marquee-x",
                `${randomBetween(range.x).toFixed(2)}px`
            );
            section.style.setProperty(
                "--marquee-y",
                `${randomBetween(range.y).toFixed(2)}px`
            );
        }

        function resetTransforms() {
            sections.forEach((section) => {
                section.style.setProperty("--marquee-rotate", "0deg");
                section.style.setProperty("--marquee-x", "0px");
                section.style.setProperty("--marquee-y", "0px");
            });
        }

        function applyChaos() {
            const range = getChaosRange();
            sections.forEach((section) => setSectionTransform(section, range));
        }

        function setChaosState(enabled: boolean, reshuffle = false) {
            if (enabled) {
                wrapper.dataset.marqueeChaos = "on";
                toggle?.setAttribute("aria-pressed", "true");
                if (reshuffle) applyChaos();
            } else {
                wrapper.dataset.marqueeChaos = "off";
                toggle?.setAttribute("aria-pressed", "false");
                resetTransforms();
            }
        }

        setChaosState(false);

        toggle?.addEventListener("click", () => {
            const isOn = wrapper.dataset.marqueeChaos === "on";
            setChaosState(!isOn, true);
        });

        wrapper.addEventListener("click", () => {
            const isOn = wrapper.dataset.marqueeChaos === "on";
            setChaosState(!isOn, true);
        });

        desktopMedia.addEventListener("change", () => {
            if (wrapper.dataset.marqueeChaos === "on") {
                applyChaos();
            }
        });
    }
</script>

<style>
    :root {
        --cursor-blur: var(--space-s, 1rem);
    }

    .shuffle-cursor {
        position: fixed;
        top: 0;
        left: 0;
        pointer-events: none;
        z-index: 9998;
        opacity: 0;
        translate: -50% -50%;
        transition: opacity 0.2s ease;
        will-change: transform;

        /* circle */
        border-radius: 100vw;
        background: rgb(from var(--color-text, #111) r g b / 0.2);
        backdrop-filter: blur(var(--cursor-blur));
        -webkit-backdrop-filter: blur(var(--cursor-blur));
        color: var(--color-bg);
        padding: var(--space-m);

        display: flex;
        align-items: center;
        justify-content: center;
    }
    .shuffle-cursor.is-visible {
        opacity: 1;
    }

    /* Both icons stacked; opacity swap avoids layout reflow */
    .cursor-icon {
        transition: opacity 0.15s ease;
    }
    .cursor-icon--play {
        position: absolute;
        opacity: 0;
    }

    .shuffle-cursor.is-visible .cursor-icon--shuffle {
        transform-origin: center center;
        animation: cursor-spin 2s linear infinite;
    }

    /* Play mode: fade between icons without layout change */
    .shuffle-cursor.is-play-mode .cursor-icon--shuffle {
        opacity: 0;
        animation: none;
    }
    .shuffle-cursor.is-play-mode .cursor-icon--play {
        opacity: 1;
    }

    @keyframes cursor-spin {
        to {
            rotate: 360deg;
        }
    }
    .marquee-wrapper.cursor-active,
    .marquee-wrapper.cursor-active * {
        cursor: none;
    }

    /* mobile: centered, no mouse tracking */
    @media (pointer: coarse) {
        .shuffle-cursor {
            top: 50%;
            left: 50%;
            translate: -50% -20%;
            transform: scale(0.75);
        }
    }
</style>

<style>
    .marquee-wrapper {
        margin-bottom: var(--space-2xl, 1rem);
        overflow-x: hidden;
        overflow-x: clip;
        /* padding-inline: var(--space-2xs, 0.5rem); */
        min-height: 50vh;
        @media (min-width: 1280px) {
            min-height: auto;
        }
    }
    :global(.marquee-wrapper > .marquee-section) {
        position: relative;
        z-index: 1;
    }
    :global(.marquee-wrapper[data-marquee-chaos="on"] > .marquee-section) {
        margin-bottom: calc(var(--space-2xs, 0.5rem) * 1);
    }
    :global(.marquee-wrapper[data-marquee-chaos="off"] > .marquee-section) {
        margin-bottom: var(--space-2xs, 0.5rem);
    }
    @media (min-width: 1280px) {
        .marquee-wrapper {
            display: flex;
            flex-direction: column;
            min-height: 100svh;
            /* padding-block: var(--space-2xs, 0.5rem); */
        }
        :global(.marquee-wrapper > section) {
            flex: 1;
        }
    }
</style>
