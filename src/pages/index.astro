---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Main from "../components/Main.astro";
import Footer from "../components/Footer.astro";
import MarqueeSection from "../components/MarqueeSection.astro";
import JsonLd from "../components/JsonLd.astro";
import { getEntry, getCollection } from "astro:content";

const mainEntry = await getEntry("main", "main");
const contact = mainEntry?.data?.contact ?? "studio@mieras.xyz";

const marqueeEntries = await getCollection("marquee");
const marquees = (marqueeEntries[0]?.data ?? []).sort(
    (a: { order: number }, b: { order: number }) => a.order - b.order
);

const seoEntry = await getEntry("seo", "seo");
const { person: p, organization: o } = seoEntry!.data;

const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: p.name,
    jobTitle: p.jobTitle,
    gender: p.gender,
    email: p.email,
    birthDate: p.birthDate,
    birthPlace: p.birthPlace,
    url: p.url,
    address: {
        "@type": "PostalAddress",
        ...p.address,
    },
};

const organizationSchema = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: o.name,
    url: o.url,
    sameAs: o.sameAs,
    logo: o.logo,
    description: o.description,
    email: o.email,
    hasMap: o.hasMap,
    openingHours: o.openingHours,
    geo: {
        "@type": "GeoCoordinates",
        latitude: o.latitude,
        longitude: o.longitude,
    },
    address: {
        "@type": "PostalAddress",
        ...o.address,
    },
};
---

<BaseLayout
    title={o.metaTitle ?? `${o.name} • ${p.name} • ${p.jobTitle}`}
    description={o.metaDescription ?? o.description}
>
    <Fragment slot="head">
        <JsonLd data={personSchema} />
        <JsonLd data={organizationSchema} />
    </Fragment>
    <Header contact={contact} />
    <section class="marquee-wrapper">
        {
            marquees.map((m) => (
                <MarqueeSection
                    text={m.text}
                    href={m.href}
                    backgroundColor={m.backgroundColor}
                    textColor={m.textColor}
                    speed={m.speed}
                />
            ))
        }
    </section>

    <Main />
    <Footer />
</BaseLayout>

<script>
    const desktopMedia = window.matchMedia("(min-width: 1280px)");
    const wrapper = document.querySelector<HTMLElement>(".marquee-wrapper");
    const toggle = document.getElementById(
        "marquee-refresh-toggle"
    ) as HTMLButtonElement | null;

    if (wrapper) {
        const sections = Array.from(
            wrapper.querySelectorAll<HTMLElement>(".marquee-section")
        );

        const chaosRangeDesktop = { rotate: 8, x: 18, y: 28 };
        const chaosRangeMobile = { rotate: 4, x: 10, y: 24 };

        const randomBetween = (maxAbs: number) =>
            (Math.random() * 2 - 1) * maxAbs;

        const getChaosRange = () =>
            desktopMedia.matches ? chaosRangeDesktop : chaosRangeMobile;

        function setSectionTransform(
            section: HTMLElement,
            range: typeof chaosRangeDesktop
        ) {
            section.style.setProperty(
                "--marquee-rotate",
                `${randomBetween(range.rotate).toFixed(2)}deg`
            );
            section.style.setProperty(
                "--marquee-x",
                `${randomBetween(range.x).toFixed(2)}px`
            );
            section.style.setProperty(
                "--marquee-y",
                `${randomBetween(range.y).toFixed(2)}px`
            );
        }

        function resetTransforms() {
            sections.forEach((section) => {
                section.style.setProperty("--marquee-rotate", "0deg");
                section.style.setProperty("--marquee-x", "0px");
                section.style.setProperty("--marquee-y", "0px");
            });
        }

        function applyChaos() {
            const range = getChaosRange();
            sections.forEach((section) => setSectionTransform(section, range));
        }

        function setChaosState(enabled: boolean, reshuffle = false) {
            if (enabled) {
                wrapper.dataset.marqueeChaos = "on";
                toggle?.setAttribute("aria-pressed", "true");
                if (reshuffle) applyChaos();
            } else {
                wrapper.dataset.marqueeChaos = "off";
                toggle?.setAttribute("aria-pressed", "false");
                resetTransforms();
            }
        }

        setChaosState(false);

        toggle?.addEventListener("click", () => {
            const isOn = wrapper.dataset.marqueeChaos === "on";
            setChaosState(!isOn, true);
        });

        desktopMedia.addEventListener("change", () => {
            if (wrapper.dataset.marqueeChaos === "on") {
                applyChaos();
            }
        });
    }
</script>

<style>
    .marquee-wrapper {
        margin-bottom: var(--space-2xl, 1rem);
        overflow-x: hidden;
        overflow-x: clip;
        /* padding-inline: var(--space-2xs, 0.5rem); */
        min-height: 50vh;
        @media (min-width: 1280px) {
            min-height: auto;
        }
    }
    :global(.marquee-wrapper > .marquee-section) {
        position: relative;
        z-index: 1;
    }
    :global(.marquee-wrapper[data-marquee-chaos="on"] > .marquee-section) {
        margin-bottom: calc(var(--space-2xs, 0.5rem) * 1);
    }
    :global(.marquee-wrapper[data-marquee-chaos="off"] > .marquee-section) {
        margin-bottom: var(--space-2xs, 0.5rem);
    }
    @media (min-width: 1280px) {
        .marquee-wrapper {
            display: flex;
            flex-direction: column;
            min-height: 100svh;
            /* padding-block: var(--space-2xs, 0.5rem); */
        }
        :global(.marquee-wrapper > section) {
            flex: 1;
        }
    }
</style>
